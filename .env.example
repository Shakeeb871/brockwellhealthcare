# Copy this file to ".env" for local development and fill in real values.
# In production, set these as environment variables on your host.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_DOMAIN=brockwellhealthcare.com
TIME_ZONE=Asia/Dubai

# --- Brand ---
BRAND_NAME=Brockwell Healthcare
BRAND_TAGLINE=Advanced Regenerative & Stem Cell Therapies

# --- Database (leave unset to use local SQLite) ---
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- UAE contact details (shown on the live UAE site) ---
UAE_PHONE=+971 50 193 1763
UAE_EMAIL=info@brockwellhealthcare.com
UAE_ADDRESS=Dubai, United Arab Emirates

# --- USA (flip to True when the US site goes live) ---
US_ENABLED=False
US_PHONE=+1 000 000 0000
US_EMAIL=info@brockwellhealthcare.com
US_ADDRESS=United States

# --- Stripe (get these from dashboard.stripe.com) ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin panel login (Django admin at /admin/). Set your own strong password.
ADMIN_USERNAME=admin
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# ---- Email (outgoing SMTP — only these are needed to send mail) ----
# Brockwell mail server; port 465 uses SSL automatically.
EMAIL_HOST=mail.brockwellhealthcare.com
EMAIL_HOST_USER=info@brockwellhealthcare.com
EMAIL_HOST_PASSWORD=your-email-account-password
# Optional overrides (auto-detected from the port otherwise):
# EMAIL_PORT=465
# EMAIL_USE_SSL=1
